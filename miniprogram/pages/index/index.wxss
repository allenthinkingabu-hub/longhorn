.container {
  padding: 24rpx;
}

.upload-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 217, 0.3);
}

.upload-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.upload-sub {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.empty-tip {
  text-align: center;
  color: #bbb;
  font-size: 26rpx;
  padding: 80rpx 0;
}

.question-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.question-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.06);
}

.item-left {
  flex: 1;
  overflow: hidden;
}

.subject-tag {
  display: inline-block;
  background: #EBF4FF;
  color: #4A90D9;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 10rpx;
}

.question-preview {
  display: block;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.item-meta {
  font-size: 22rpx;
  color: #aaa;
}

.item-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 16rpx;
}
